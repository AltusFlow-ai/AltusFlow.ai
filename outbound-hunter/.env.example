# ─────────────────────────────────────────────────────────────────────
# AltusFlow Outbound Hunter — Environment Variables
# Copy this to .env and fill in your keys
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────
# PostgreSQL (production — Supabase or Neon recommended):
#   Supabase:  Project Settings → Database → Connection string → URI mode
#   Neon:      Dashboard → Connection Details → copy the postgres:// URI
# SQLite (local dev):  leave unset — defaults to sqlite:///./outbound_hunter.db
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── HubSpot ─────────────────────────────────────────────────────────
# Private App token — HubSpot > Settings > Integrations > Private Apps
# Scopes required: crm.objects.contacts.write, crm.objects.deals.write,
#                  crm.objects.notes.write, crm.schemas.contacts.write
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Find pipeline/stage IDs via:
#   GET https://api.hubapi.com/crm/v3/pipelines/deals
#   (auth with your token — lists all pipelines + stage IDs)
HUBSPOT_PIPELINE_ID=
HUBSPOT_STAGE_1_ID=
# Stage to move a deal to when a Calendly meeting is booked
HUBSPOT_STAGE_MEETING_BOOKED_ID=

# ─── Calendly (free plan — polling) ──────────────────────────────────
# Personal access token: Calendly → Account → Integrations → API & Webhooks
# Free plan supports polling only. Add webhook handler when you upgrade to Standard ($10/mo).
CALENDLY_TOKEN=
# How often to poll for new bookings (default: 15 minutes)
CALENDLY_POLL_MINUTES=15

# ─── Claude AI ───────────────────────────────────────────────────────
# Your Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Signal scanning ─────────────────────────────────────────────────
# Apify — LinkedIn (apify/linkedin-post-search-scraper) +
#          Facebook Groups (apify/facebook-groups-scraper)
# Get from: console.apify.com → Settings → Integrations → API Token
APIFY_API_TOKEN=

# Facebook scraper tuning
FB_POSTS_PER_GROUP=50

# Reddit API — free, 60 req/min
# Register a "script" app at reddit.com/prefs/apps
# App type: script | Redirect URI: http://localhost:8080
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AltusFlowHunter/1.0

# Reddit scraper tuning
REDDIT_POSTS_PER_SEARCH=25
REDDIT_HOT_POSTS=50

# ─── Niche / platform config ──────────────────────────────────────────
# Comma-separated list of niche slugs to scan (leave blank for all):
# financial-advisors,business-coaches,recruiters,commercial-real-estate,msps,altusflow-own
ACTIVE_NICHES=

# ─── Inbound voice — Morgan AI Receptionist ──────────────────────────
# Vapi handles the AI conversation on inbound calls from your Twilio number.
# Set up: console.vapi.ai → Phone Numbers → Import Twilio Number → set server URL
#   Server URL: https://yourdomain.com/webhooks/voice/inbound
#   Call ended webhook: https://yourdomain.com/webhooks/voice/call-ended
VAPI_API_KEY=

# Your AltusFlow inbound Twilio number (registered in Vapi dashboard)
TWILIO_ALTUSFLOW_NUMBER=+1

# Closer notification — fires when Morgan books a call or escalates
# Accepts any HTTP POST endpoint: Slack incoming webhook, Make.com, Zapier catch hook
CLOSER_WEBHOOK_URL=
CLOSER_EMAIL=                # backup notification if webhook not set
CLOSER_NAME=                 # used in HubSpot task assignment e.g. Austin

# ─── App settings ────────────────────────────────────────────────────
# Client ID — appears in UTM campaign strings and HubSpot contact properties
CLIENT_ID=ALT00

# Base URL for UTM-tagged CTA links in outreach messages
SITE_URL=https://altusflow.ai

# Flask session secret — change to a long random string in production
FLASK_SECRET=change-this-to-something-random

# Encryption key for API token storage (Fernet AES-256).
# Any string works — the key is SHA-256 derived. Keep this secret and stable:
# changing it will invalidate all stored platform tokens (you'll need to re-enter them).
# Generate a good one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret

# Hours before /health returns 503 (UptimeRobot alert threshold)
ALERT_HOURS=26

# Minimum ICP score to store a prospect (1-10)
MIN_ICP_SCORE=4
