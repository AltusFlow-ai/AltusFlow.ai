# AltusFlow Outbound Hunter — Local Windows dev config
# Cost-save launch mode: Reddit + Claude + HubSpot only
# Copy values here from your accounts, then: set FLASK_SECRET below

# ── Dev identity (NO_AUTH mode) ───────────────────────────────────────────────
DEV_COMPANY_NAME=AltusFlow

# ── Required now ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

SCRAPEBADGER_API_KEY=
SCRAPEBADGER_BASE_URL=https://api.scrapebadger.io/v1

TWITTER_BEARER_TOKEN=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AltusFlowHunter/1.0

# HubSpot private app token (portal 246530361)
# Scopes: crm.objects.contacts.write, crm.objects.deals.write,
#         crm.objects.notes.write, crm.schemas.contacts.write
HUBSPOT_TOKEN=

HUBSPOT_PORTAL_ID=246530361
HUBSPOT_PIPELINE_ID=
HUBSPOT_STAGE_1_ID=
HUBSPOT_STAGE_MEETING_BOOKED_ID=

SECRET_KEY=
FLASK_SECRET=

DATABASE_URL=sqlite:///altusflow.db

NO_AUTH=true
USE_POD_ORCHESTRATOR=true
CLIENT_ID=ALT00
ALTUSFLOW_CLIENT_ID=ALT00

MIN_ICP_SCORE=4
FLASK_PORT=5000
SCAN_CRON_HOUR=6
SCAN_CRON_MINUTE=0
ALERT_HOURS=26
SITE_URL=http://localhost:5000

REDDIT_POSTS_PER_SEARCH=25
REDDIT_HOT_POSTS=50


# ── Add after first client ─────────────────────────────────────────────────────
# APIFY_API_TOKEN=
# FB_POSTS_PER_GROUP=50

# ── Add when Meta ads are live ────────────────────────────────────────────────
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=

# ── Add when voice is activated ───────────────────────────────────────────────
# VAPI_API_KEY=
# TWILIO_ALTUSFLOW_NUMBER=+1
# CLOSER_WEBHOOK_URL=
# CLOSER_EMAIL=
# CLOSER_NAME=

# ── Add when Calendly is on paid plan ─────────────────────────────────────────
# CALENDLY_TOKEN=
# CALENDLY_POLL_MINUTES=15

# ── Add for daily email digest ────────────────────────────────────────────────
# DIGEST_EMAIL_TO=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# (OR) SENDGRID_API_KEY=
